---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Spotlight from '../components/Spotlight.astro';
import NavProgress from '../components/NavProgress.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Engineering, security, and ops-intelligence articles from the AnantaOps team.',
  ogImage = '/og-image.png',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// Sign up free at https://www.goatcounter.com, pick a site code, and swap it in here.
// e.g. site code "anantaops-articles" -> https://anantaops-articles.goatcounter.com
const GOATCOUNTER_CODE = 'anantaops';
const goatcounterEnabled = GOATCOUNTER_CODE !== 'REPLACE_WITH_YOUR_GOATCOUNTER_CODE';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/anantaops-logo.png" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="AnantaOps Articles" href="/rss.xml" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="AnantaOps Articles" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <ClientRouter />
    {goatcounterEnabled && (
      <script
        data-goatcounter={`https://${GOATCOUNTER_CODE}.goatcounter.com/count`}
        async
        src="//gc.zgo.at/count.js"
      />
    )}
  </head>
  <body>
    <NavProgress />
    <Spotlight />
    <Nav transition:persist="nav" />
    <main class="pt-16" transition:animate="fade">
      <slot />
    </main>
    <Footer />
  </body>
</html>
