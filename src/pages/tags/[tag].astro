---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getPublishedArticles, getTagCounts, MAX_VISIBLE_TAGS } from '../../lib/articles';

export async function getStaticPaths() {
  const tagCounts = await getTagCounts();
  return tagCounts.map(({ tag }) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allArticles = await getPublishedArticles();
const articles = allArticles.filter((a) => a.data.tags.includes(tag as string));
const allTags = await getTagCounts();

const currentEntry = allTags.find((t) => t.tag === tag);
const otherTags = allTags.filter((t) => t.tag !== tag);
const visibleTags = currentEntry
  ? [currentEntry, ...otherTags.slice(0, MAX_VISIBLE_TAGS - 1)]
  : otherTags.slice(0, MAX_VISIBLE_TAGS);
const hiddenTagCount = allTags.length - visibleTags.length;
---
<Layout title={`${tag} — Articles — AnantaOps`} description={`Articles tagged "${tag}" from the AnantaOps team.`}>
  <section class="relative overflow-hidden border-b border-border py-20 lg:py-24">
    <div class="absolute inset-0 grid-pattern" aria-hidden="true"></div>
    <img
      src="/anantaops-logo.png"
      alt=""
      width="700"
      height="700"
      class="pointer-events-none absolute -right-24 top-1/2 hidden -translate-y-1/2 opacity-10 dark:brightness-0 dark:invert lg:block"
      aria-hidden="true"
    />
    <div class="container relative mx-auto max-w-5xl px-6">
      <a href="/" class="animate-fade-up text-sm text-muted-foreground hover:text-foreground">← All articles</a>
      <h1 class="animate-fade-up stagger-1 mt-4 text-3xl font-bold tracking-tight text-gradient sm:text-4xl">
        #{tag}
      </h1>
      <p class="animate-fade-up stagger-2 mt-3 text-muted-foreground">
        {articles.length} article{articles.length === 1 ? '' : 's'} tagged “{tag}”
      </p>

      <div class="animate-fade-up stagger-3 mt-6 flex flex-wrap gap-2">
        {visibleTags.map(({ tag: t, count }) => (
          <a href={`/tags/${t}/`} class={`tag-pill ${t === tag ? 'active' : ''}`}>
            {t} <span class="ml-1 opacity-60">{count}</span>
          </a>
        ))}
        {hiddenTagCount > 0 && (
          <a href="/tags/" class="tag-pill tag-pill-more">
            More <span class="ml-1 opacity-60">+{hiddenTagCount}</span>
          </a>
        )}
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto max-w-5xl px-6">
      <div class="grid gap-6 sm:grid-cols-2">
        {articles.map((article, i) => <ArticleCard article={article} index={i} />)}
      </div>
    </div>
  </section>
</Layout>
