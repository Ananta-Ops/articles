---
import Logo from './Logo.astro';

const currentPath = new URL(Astro.request.url).pathname;
const isHome = currentPath === '/';

const links = [
  { label: 'Articles', href: '/' },
  { label: 'Product', href: 'https://anantaops.github.io' },
  { label: 'Contact', href: 'https://anantaops.github.io#contact' },
];
---
<header id="site-nav" class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-all duration-300">
  <div class="container mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <a href="/" class="flex items-center">
      <Logo />
    </a>
    <nav class="hidden items-center gap-8 text-sm text-muted-foreground sm:flex">
      {links.map((l) => (
        <a
          href={l.href}
          class={`nav-link transition-colors hover:text-foreground ${l.href === '/' && isHome ? 'text-foreground' : ''}`}
        >
          {l.label}
        </a>
      ))}
    </nav>
    <button
      id="nav-toggle"
      class="rounded-md p-2 text-muted-foreground sm:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden border-t border-border bg-background/95 backdrop-blur-xl sm:hidden">
    <nav class="container mx-auto flex max-w-5xl flex-col gap-1 px-6 py-4">
      {links.map((l) => (
        <a href={l.href} class="rounded-md px-3 py-2 text-sm text-muted-foreground hover:bg-muted hover:text-foreground">
          {l.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 12) {
      nav.classList.add('border-border/60', 'bg-background/70', 'backdrop-blur-xl');
    } else {
      nav.classList.remove('border-border/60', 'bg-background/70', 'backdrop-blur-xl');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');
  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconMenu?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
